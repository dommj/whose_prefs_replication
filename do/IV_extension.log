            gini_mkt common_law iv_interaction

. 
.     // Capture the Kleibergen-Paap rk Wald F statistic (Robust version of Cra
> gg-Donald)
.     quietly estat firststage

.     matrix first = r(singleresults)

.     estadd scalar kp_f = r(idstat)

added scalar:
               e(kp_f) =  .

. 
. *----------------------------------------------------------------------------
> ---
. * 3. Export Identification Table
. *----------------------------------------------------------------------------
> ---
. # delimit ;
delimiter now ;
. esttab fs_cbc fs_int second_stage using "../output/iv_identification_table.te
> x", replace 
>     b(3) se(3) label booktabs style(tex)
>     mgroups("First Stage" "Second Stage", pattern(1 0 1) prefix(\multicolumn{
> @span}{c}{) suffix(}) span)
>     mtitle("CBC Rate" "Bottom $\times$ CBC" "Redistribution")
>     stats(f_stat kp_f N, fmt(2 2 0) 
>           labels("F-stat (Instruments)" "K-P Rank F-stat" "N"))
>     title("IV Results: Instrumenting with Legal Origins")
>     interaction(" $\times$ ")  nonotes stardetach nostar ;
(file ../output/iv_identification_table.tex not found)
(output written to ../output/iv_identification_table.tex)

. # delimit cr
delimiter now cr
